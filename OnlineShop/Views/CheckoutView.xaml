<UserControl x:Class="OnlineShop.Views.CheckoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Форма заказа -->
            <GroupBox Header="Данные для доставки" 
                      Grid.Row="0" 
                      Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <!-- ФИО -->
                    <TextBlock Text="ФИО:" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtFullName" 
                             Height="35" 
                             Margin="0,0,0,10"
                             FontSize="14"/>

                    <!-- Email -->
                    <TextBlock Text="Email:" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtEmail" 
                             Height="35" 
                             Margin="0,0,0,10"
                             FontSize="14"/>

                    <!-- Адрес -->
                    <TextBlock Text="Адрес доставки:" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtAddress" 
                             Height="80" 
                             AcceptsReturn="True" 
                             TextWrapping="Wrap"
                             FontSize="14"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </GroupBox>

            <!-- Товары в заказе -->
            <GroupBox Header="Состав заказа" 
                      Grid.Row="1" 
                      Margin="0,0,0,20">
                <ListView ItemsSource="{Binding CartItems}" 
                          Height="200">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Товар" 
                                            DisplayMemberBinding="{Binding Product.Name}" 
                                            Width="200"/>
                            <GridViewColumn Header="Кол-во" 
                                            DisplayMemberBinding="{Binding Quantity}" 
                                            Width="80"/>
                            <GridViewColumn Header="Цена" 
                                            Width="100">
                                <GridViewColumn.DisplayMemberBinding>
                                    <MultiBinding StringFormat="{}{0} руб.">
                                        <Binding Path="Product.Price"/>
                                    </MultiBinding>
                                </GridViewColumn.DisplayMemberBinding>
                            </GridViewColumn>
                            <GridViewColumn Header="Сумма" 
                                            Width="100">
                                <GridViewColumn.DisplayMemberBinding>
                                    <MultiBinding StringFormat="{}{0} руб.">
                                        <Binding Path="TotalPrice"/>
                                    </MultiBinding>
                                </GridViewColumn.DisplayMemberBinding>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

            <!-- Кнопка оформления -->
            <Border Grid.Row="2" 
                    Background="#F8F9FA" 
                    Padding="20">
                <StackPanel>
                    <TextBlock FontSize="20" 
                               FontWeight="Bold" 
                               Margin="0,0,0,15"
                               Foreground="#2C3E50">
                        <Run Text="Итого к оплате: "/>
                        <Run Text="{Binding CartTotalPrice}"/>
                        <Run Text=" руб."/>
                    </TextBlock>

                    <Button Content="Подтвердить заказ" 
                            Click="PlaceOrder_Click"
                            Padding="40,15"
                            FontSize="16"
                            Background="#27AE60" 
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#229954"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>